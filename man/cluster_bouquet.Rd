  week    = rep(weeks, 6L),
  station = rep(paste0("S", 1:6), each = n),
  level_m = c(
    8.5 + 0.8 * season + cumsum(rnorm(n,  0.00, 0.2)),
    8.3 + 0.7 * season + cumsum(rnorm(n,  0.01, 0.2)),
