    9.3 + 1.0 * season + cumsum(rnorm(n, -0.02, 0.2))
  )
)

# Default: PCA + hclust, auto k
clustered <- cluster_bouquet(gw_long,
  time_col = week, series_col = station, value_col = level_m)

